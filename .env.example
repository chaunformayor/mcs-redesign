# ── Neon Postgres ──────────────────────────────────────────────────────────────
# Get these from your Neon dashboard → Connection Details
# Use the "Pooled connection" string for DATABASE_URL (works best in serverless)
# Use the "Direct connection" string for DIRECT_URL (used by Prisma migrations)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb"

# ── Admin Auth ─────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
ADMIN_JWT_SECRET="change-this-to-a-long-random-string-in-production"
# Password used to log in to /admin-login
ADMIN_PASSWORD="changeme123"

# ── Vercel Blob ────────────────────────────────────────────────────────────────
# Auto-set by Vercel when you add Blob storage in the dashboard
# (Storage → Create → Blob → link to project)
BLOB_READ_WRITE_TOKEN=""
